msgstr "De naam van de ingebouwde monitor."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
msgid "Minimum brightness."
msgstr "Minimale helderheid."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
msgid "Minimum brightness level."
msgstr "Minimaal helderheidsniveau."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
