msgstr "Gebruik de normale achtergrondverlichting."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
msgid "Monitors."
msgstr "Monitors."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
msgid "The monitors whose brightness should be adjusted."
msgstr "De monitors waarvan de helderheid wordt aangepast."

#: schemas/org.gnome.shell.extensions.soft-brightness-plus.gschema.xml
